          "query": "from(bucket:\"telecom_metrics\") |> range(start:v.timeRangeStart, stop:v.timeRangeStop) |> filter(fn:(r)=>r._measurement==\"cell_kpi\" and r._field==\"connected_ues\") |> aggregateWindow(every:v.windowPeriod, fn:last, createEmpty:false) |> group(columns:[\"_time\"]) |> sum() |> group()",
