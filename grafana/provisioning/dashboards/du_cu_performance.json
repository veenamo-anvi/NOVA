{
  "uid": "nova-du-cu-perf",
  "title": "DU/CU Performance",
  "tags": [
    "nova"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "panels": [
    {
      "id": 24,
      "type": "timeseries",
      "title": "DU CPU (%)",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket:\"telecom_metrics\") |> range(start:v.timeRangeStart, stop:v.timeRangeStop) |> filter(fn:(r)=>r._measurement==\"du_kpi\" and r._field==\"cpu_pct\") |> aggregateWindow(every:v.windowPeriod, fn:mean, createEmpty:false)",
          "refId": "A"
        }
      ]
    },
