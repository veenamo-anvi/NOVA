# ============================================================================
# NOVA — Telecom Network Automation : environment configuration
# Copy to `.env` and adjust. Never commit the real .env.
# ============================================================================

# ---- InfluxDB (time-series KPI store) --------------------------------------
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=telecom-super-secret-auth-token-2026
INFLUX_ORG=telecom
INFLUX_BUCKET=telecom_metrics
# First-boot setup (docker influxdb2 image)
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=admin-password-2026
INFLUXDB_INIT_RETENTION=30d

# ---- Grafana ---------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- Topology (source of truth) --------------------------------------------
TOPOLOGY_FILE=/config/topology.json
TOPO_POLL_SEC=5

# ---- Service URLs (in-cluster) ---------------------------------------------
CONTROLLER_URL=http://controller:8080
PLANNING_URL=http://planning-api:8081
ORCHESTRATOR_URL=http://orchestrator:8082

# ---- Orchestrator LLM backend ----------------------------------------------
# Backend selection order: Claude CLI (CLAUDE_CLI_PATH set & present) ->
# Anthropic API (ANTHROPIC_API_KEY) -> Gemini (GOOGLE_API_KEY) -> mock.
CLAUDE_CLI_PATH=/usr/bin/claude
ANTHROPIC_MODEL_NAME=sonnet
# Anthropic API backend (direct SDK, native tool-calling)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Gemini fallback
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- KPI agent -------------------------------------------------------------
POLL_INTERVAL_SEC=30
MODEL_PATH=kpi_model.pt
MIN_CONFIDENCE=0.70
# Rule-based fallback thresholds
OVERLOAD_PRB_PCT=85
UNDERLOAD_PRB_PCT=20
SINR_MIN_DB=5
POWER_WASTE_W=500
POWER_WASTE_MIN_UES=15

# ---- Planning engine -------------------------------------------------------
# mip_time_limit_sec is a request field, not an env var (see spec).
